# ─────────────────────────────────────────────────────────────────
#  LogFlow — configuration du déploiement Docker
#  Déploiement ultra-simple :  cp .env.example .env  →  édite ci-dessous
#                               →  docker compose up -d
# ─────────────────────────────────────────────────────────────────

# Mots de passe de la base (À CHANGER avant tout déploiement réel)
MARIADB_ROOT_PASSWORD=change_me_root
DB_NAME=logflow
DB_USER=logflow
DB_PASS=change_me_logflow

# Port HTTP exposé sur la machine hôte → http://localhost:<APP_PORT>
APP_PORT=8085

# URL publique de LogFlow, telle que les agents la joindront.
# Pré-remplit les commandes d'installation d'agent (page Setup).
# Mettez l'adresse réellement accessible par vos machines surveillées,
# ex. http://192.0.2.10:8085 ou https://logs.mondomaine.com
# (laissez vide pour la régler plus tard dans Setup).
SERVER_URL=http://localhost:8085
