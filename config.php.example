<?php
// Copiez ce fichier en `config.php` (jamais versionné, voir .gitignore),
// ou laissez les variables d'environnement le renseigner (déploiement Docker).
define('DB_HOST', getenv('DB_HOST') ?: 'localhost');
define('DB_NAME', getenv('DB_NAME') ?: 'logflow');
define('DB_USER', getenv('DB_USER') ?: 'logflow');
define('DB_PASS', getenv('DB_PASS') ?: 'CHANGE_ME');     // mot de passe MariaDB
define('DB_CHARSET', 'utf8mb4');

define('APP_NAME', getenv('APP_NAME') ?: 'LogFlow');
define('APP_VERSION', '1.0.0');

define('LOGS_PER_PAGE', (int)(getenv('LOGS_PER_PAGE') ?: 100));
define('MAX_LOG_AGE_DAYS', (int)(getenv('MAX_LOG_AGE_DAYS') ?: 90));
